{
  "$schema": "https://railway.app/schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacks": {
      "image": "ubuntu/prompt:22.04",
      "install": [
        "apt-get update && apt-get install -y ffmpeg python3 python3-pip"
      ]
    }
  },
  "deploy": {
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
